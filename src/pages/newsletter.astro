---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
---

<Layout>
  <SEO
    slot="head"
    title="Modern Compass Newsletter — One Topic. Four Directions."
    description="Every issue explores one idea across Self, Trust, Character, and Relationships. Once a month. Free access to the Map Where You Are assessment for subscribers."
    canonical="https://themoderncompass.io/newsletter"
    keywords="personal development newsletter, modern compass newsletter, self improvement, character development, relationships growth, monthly newsletter"
  />

  <!-- Hero Section -->
  <section class="hero">
    <div class="wrap narrow">
      <h1 class="headline">One topic. Four directions.<br>A new way to see yourself.</h1>
      <p class="subline">Every issue explores one idea across Self, Trust, Character, and Relationships.</p>

      <p class="assessment-frame">The <a href="https://map.themoderncompass.io" class="assessment-link">self-assessment</a> is where the framework starts—it maps where you stand across all four directions so you know which deserves your attention first. The newsletter is what deepens that work over time.</p>

      <div class="built-for">
        <span class="built-for-label">Built for</span>
        <span class="arrow">→</span>
        <span class="cycling-text" id="cyclingText"></span><span class="cursor">|</span>
      </div>

      <!-- Subscribe Form -->
      <div class="embed-wrap">
        <iframe
          id="beehiiv-subscribe-form"
          src="https://subscribe-forms.beehiiv.com/261a3276-40ab-431a-8523-c85bec095b96"
          frameborder="0"
          scrolling="yes"
          style="width: 100%; max-width: 480px; height: 180px; border: none; border-radius: 8px; background-color: transparent; display: block; margin: 0 auto;"
          title="Subscribe to Modern Compass on Beehiiv"
        ></iframe>
        <p class="frequency">Once a month.</p>
        <p class="assessment-cta">Not sure where to start? <a href="https://map.themoderncompass.io" class="assessment-link">Take the self-assessment first →</a></p>
      </div>

      <!-- Sample Issue Preview -->
      <div class="sample-issue">
        <button class="sample-btn" id="sampleIssueBtn">See a recent issue →</button>
      </div>
    </div>
  </section>

  <!-- Sample Issue Modal -->
  <div id="sampleModal" class="modal" role="dialog" aria-modal="true" aria-label="Recent issue preview">
    <div class="modal-inner">
      <button class="modal-close" id="modalClose" aria-label="Close preview">&times;</button>
      <iframe
        src="https://themoderncompass.io/blog/character-is-product-you-display"
        title="Recent Modern Compass issue: Character Is the Product You Display"
        class="modal-frame"
        loading="lazy"
      ></iframe>
      <div class="modal-fallback">
        <p>Can't load preview inline?</p>
        <a href="https://themoderncompass.io/blog/character-is-product-you-display" target="_blank" rel="noopener">Open in new tab →</a>
      </div>
    </div>
  </div>

  <!-- Benefit Blocks -->
  <section class="benefits">
    <div class="wrap">
      <div class="benefits-grid">

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="g1" x1="0" y1="48" x2="48" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#F97316"/>
                  <stop offset="50%" stop-color="#A855F7"/>
                  <stop offset="100%" stop-color="#06B6D4"/>
                </linearGradient>
              </defs>
              <!-- Compass rose: four arms -->
              <line x1="24" y1="6" x2="24" y2="42" stroke="url(#g1)" stroke-width="3" stroke-linecap="round"/>
              <line x1="6" y1="24" x2="42" y2="24" stroke="url(#g1)" stroke-width="3" stroke-linecap="round"/>
              <circle cx="24" cy="24" r="5" fill="url(#g1)"/>
              <polygon points="24,8 27,20 24,17 21,20" fill="url(#g1)"/>
            </svg>
          </div>
          <h3>See your life from four angles at once.</h3>
          <p>Every issue takes one topic and shows you how it plays out across Self, Trust, Character, and Relationships.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="g2" x1="0" y1="48" x2="48" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#F97316"/>
                  <stop offset="50%" stop-color="#EC4899"/>
                  <stop offset="100%" stop-color="#A855F7"/>
                </linearGradient>
              </defs>
              <!-- Hourglass / timer -->
              <path d="M14 6h20M14 42h20M16 6l8 14 8-14M16 42l8-14 8 14" stroke="url(#g2)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Short enough to read, specific enough to stick.</h3>
          <p>One topic, four brief perspectives. No filler. Read it in 3 minutes and think about it the rest of the day.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="g3" x1="0" y1="48" x2="48" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#10B981"/>
                  <stop offset="100%" stop-color="#06B6D4"/>
                </linearGradient>
              </defs>
              <!-- Map / assessment pin -->
              <rect x="8" y="10" width="32" height="26" rx="3" stroke="url(#g3)" stroke-width="3"/>
              <line x1="8" y1="18" x2="40" y2="18" stroke="url(#g3)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="20" y1="10" x2="20" y2="36" stroke="url(#g3)" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="30" cy="28" r="4" fill="url(#g3)"/>
            </svg>
          </div>
          <h3>Free access to the Map Where You Are assessment.</h3>
          <p>Subscribers get access to the self-assessment tool that shows you which direction needs your attention first. Other Modern Compass tools will be at your disposal in the welcome email and as new apps or tools are released.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="g4" x1="0" y1="48" x2="48" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#8B5CF6"/>
                  <stop offset="100%" stop-color="#3B82F6"/>
                </linearGradient>
              </defs>
              <!-- Book with bookmark -->
              <path d="M12 8h20a2 2 0 012 2v28a2 2 0 01-2 2H12a2 2 0 01-2-2V10a2 2 0 012-2z" stroke="url(#g4)" stroke-width="3"/>
              <line x1="10" y1="16" x2="34" y2="16" stroke="url(#g4)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="10" y1="23" x2="26" y2="23" stroke="url(#g4)" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M30 8v14l-4-3-4 3V8" stroke="url(#g4)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>First to know when the book launches.</h3>
          <p>The Modern Compass book arrives in 2027. Subscribers get early access, pre-order details, and behind-the-scenes updates.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq">
    <div class="wrap narrow">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">

        <div class="faq-item">
          <h3>What is Modern Compass?</h3>
          <p>Modern Compass is a personal development framework built around four directions: Self, Trust, Character, and Relationships. Each direction has progressive layers that help you see where you actually stand, not where you think you stand. The framework also identifies Drag, which is what keeps you stuck at each layer, and gives you practical language and concepts to work through it. The book goes deep. The newsletter gives you a taste every month.</p>
        </div>

        <div class="faq-item">
          <h3>What is the Modern Compass newsletter?</h3>
          <p>One email per month that takes a single topic and explores it across the four directions. Each issue includes a reflective prompt and behind-the-scenes updates on the book launching in 2027.</p>
        </div>

        <div class="faq-item">
          <h3>Who is Modern Compass for?</h3>
          <p>People who can name what's wrong in their life but not why. You've tried the books, the podcasts, the advice. Modern Compass aims to give you the map to decide who you will become next.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Modern Compass Newsletter",
    "description": "One topic. Four directions. A new way to see yourself. Monthly newsletter exploring Self, Trust, Character, and Relationships.",
    "url": "https://themoderncompass.io/newsletter",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": [
        {
          "@type": "Question",
          "name": "What is Modern Compass?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Modern Compass is a personal development framework built around four directions: Self, Trust, Character, and Relationships. Each direction has progressive layers that help you see where you actually stand, not where you think you stand."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Modern Compass newsletter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "One email per month that takes a single topic and explores it across the four directions. Each issue includes a reflective prompt and behind-the-scenes updates on the book launching in 2027."
          }
        },
        {
          "@type": "Question",
          "name": "Who is Modern Compass for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "People who can name what's wrong in their life but not why. You've tried the books, the podcasts, the advice. Modern Compass aims to give you the map to decide who you will become next."
          }
        }
      ]
    }
  }
  </script>

</Layout>

<style>
  /* ── Layout helpers ── */
  .wrap { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
  .wrap.narrow { max-width: 720px; }

  /* ── Hero ── */
  .hero {
    padding: 56px 0 40px;
    text-align: center;
    background: #ffffff;
  }

  .headline {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: #111;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .subline {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #444;
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .assessment-frame {
    font-size: clamp(0.95rem, 1.8vw, 1.05rem);
    color: #444;
    margin: 0 0 28px;
    line-height: 1.6;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .assessment-link {
    color: #8b5cf6;
    font-weight: 600;
    text-decoration: underline;
  }

  .assessment-cta {
    font-size: 0.9rem;
    color: #666;
    margin: 10px 0 0;
    text-align: center;
  }

  /* Built-for typewriter */
  .built-for {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 600;
    color: #111;
    margin: 0 0 28px;
    flex-wrap: nowrap;
  }

  .built-for-label {
    color: #8b5cf6;
    white-space: nowrap;
  }

  .arrow { color: #8b5cf6; }

  .cycling-text {
    display: inline-block;
    min-width: 260px;
    text-align: left;
    white-space: nowrap;
  }

  .cursor {
    color: #8b5cf6;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Embed */
  .embed-wrap {
    margin: 0 auto 24px;
    max-width: 500px;
  }

  .frequency {
    font-size: 0.9rem;
    color: #888;
    margin: 8px 0 0;
    text-align: center;
  }

  /* Sample issue button */
  .sample-issue { margin-bottom: 8px; }

  .sample-btn {
    background: none;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #555;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .sample-btn:hover {
    border-color: #8b5cf6;
    color: #8b5cf6;
  }

  /* ── Sample issue modal ── */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.75);
    padding: 16px;
    align-items: center;
    justify-content: center;
  }

  .modal.open { display: flex; }

  .modal-inner {
    position: relative;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 860px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
  }

  .modal-close {
    position: absolute;
    top: 10px;
    right: 14px;
    background: rgba(0,0,0,0.55);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 18px;
    color: #fff;
    cursor: pointer;
    line-height: 1;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-frame {
    width: 100%;
    flex: 1;
    min-height: 400px;
    max-height: calc(88vh - 48px);
    border: none;
  }

  .modal-fallback {
    padding: 8px 16px;
    text-align: center;
    background: #f9fafb;
    border-top: 1px solid #e5e7eb;
    font-size: 0.85rem;
    color: #666;
    flex-shrink: 0;
  }

  .modal-fallback a { color: #8b5cf6; font-weight: 600; text-decoration: none; }
  .modal-fallback a:hover { text-decoration: underline; }
  .modal-fallback p { margin: 0 0 4px; }

  /* ── Benefits ── */
  .benefits {
    padding: 56px 0;
    background: #f8fafc;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .benefit-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 24px;
  }

  .benefit-icon {
    margin-bottom: 14px;
  }

  .benefit-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .benefit-card p {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.6;
    margin: 0;
  }

  /* ── FAQ ── */
  .faq {
    padding: 56px 0;
    background: #ffffff;
  }

  .faq h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #111;
    margin: 0 0 32px;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq-item {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px 24px;
  }

  .faq-item h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 8px;
  }

  .faq-item p {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.65;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero { padding: 36px 0 28px; }

    .built-for {
      font-size: 0.95rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .cycling-text { min-width: 180px; }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .faq { padding: 40px 0; }
    .benefits { padding: 40px 0; }
  }
</style>

<script is:inline>
  document.body.classList.add('newsletter-page');

  // Meta Pixel & GA conversion tracking
  window.addEventListener('message', function(event) {
    if (event.data && typeof event.data === 'string' && event.data.includes('beehiiv')) {
      if (typeof fbq !== 'undefined') {
        fbq('track', 'Lead', { content_name: 'Newsletter Signup', content_category: 'Newsletter', value: 5.00, currency: 'USD' });
      }
      if (typeof gtag !== 'undefined') {
        gtag('event', 'generate_lead', { event_category: 'Newsletter', event_label: 'Newsletter Signup', value: 5.00 });
      }
    }
  });

  // Typewriter animation
  document.addEventListener('DOMContentLoaded', function() {
    const personas = [
      'Lost twenty-somethings',
      'Wandering thirty-somethings',
      'Searching forty-somethings',
      'Framework seekers',
      'Assessment believers',
      'Patient builders',
      'Anti-quick-hack thinkers'
    ];

    const el = document.getElementById('cyclingText');
    let idx = 0, charIdx = 0, deleting = false;

    function type() {
      const full = personas[idx];
      charIdx = deleting ? charIdx - 1 : charIdx + 1;
      el.textContent = full.substring(0, charIdx);

      let delay = deleting ? 30 : 60;
      if (!deleting && charIdx === full.length) { delay = 2000; deleting = true; }
      else if (deleting && charIdx === 0) { deleting = false; idx = (idx + 1) % personas.length; delay = 500; }

      setTimeout(type, delay);
    }
    type();
  });

  // Sample issue modal
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('sampleModal');
    const openBtn = document.getElementById('sampleIssueBtn');
    const closeBtn = document.getElementById('modalClose');

    openBtn.addEventListener('click', function() { modal.classList.add('open'); });
    closeBtn.addEventListener('click', function() { modal.classList.remove('open'); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.classList.remove('open');
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') modal.classList.remove('open');
    });
  });
</script>
