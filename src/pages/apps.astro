---
import Layout from '../layouts/Layout.astro'
import SEO from '../components/SEO.astro'
---

<Layout>
  <SEO
    slot="head"
    title="Apps | Modern Compass"
    description="Apps built by Modern Compass to help you build better habits, accountability, and self-control. Explore Impulse Wallet, a gamified accountability app for tracking your wins and losses."
    canonical="https://themoderncompass.io/apps"
    keywords="impulse wallet, accountability app, habit tracking, self-control app, gamified personal growth, modern compass apps"
  />

  <section class="apps-page">
    <div class="page-header">
      <h1>Apps</h1>
      <p class="intro">Tools built from the Modern Compass framework to help you take action, build accountability, and grow. One small choice at a time.</p>
    </div>

    <!-- Map Where You Are Assessment -->
    <div class="featured-app assessment-card">
      <div class="featured-badge new-badge">New</div>
      <div class="featured-content">
        <div class="app-info">
          <div class="app-icon assessment-icon">
            <svg width="64" height="64" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="ai-grad" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                </linearGradient>
              </defs>
              <circle cx="32" cy="32" r="28" fill="none" stroke="url(#ai-grad)" stroke-width="3"/>
              <line x1="32" y1="4" x2="32" y2="60" stroke="url(#ai-grad)" stroke-width="2" opacity="0.3"/>
              <line x1="4" y1="32" x2="60" y2="32" stroke="url(#ai-grad)" stroke-width="2" opacity="0.3"/>
              <polygon points="32,14 36,29 32,26 28,29" fill="url(#ai-grad)"/>
              <polygon points="32,50 36,35 32,38 28,35" fill="#d1d5db"/>
              <circle cx="32" cy="32" r="4" fill="url(#ai-grad)"/>
            </svg>
          </div>
          <div class="app-meta">
            <h2>Map Where You Are</h2>
            <p class="app-tagline">A 10-minute digital self-assessment across the four Modern Compass directions</p>
          </div>
        </div>

        <p class="app-description">
          Before you can decide who you want to become, you need an honest read on where you actually are. <strong>Map Where You Are</strong> guides you through 27 questions across Self, Trust, Character, and Relationships, the four directions of the Modern Compass, and returns an AI-personalized report that reflects where you stand right now.
        </p>
        <p class="app-description">
          The more honest you are answering the questions, the more valuable the report. Most people walk away with at least one insight they'd been feeling but hadn't connected the dots on yet.
        </p>

        <!-- Assessment Screenshot -->
        <div class="app-screenshot-wrap">
          <button class="screenshot-btn" id="assessment-screenshot-btn" aria-label="View assessment result example">
            <img src="/assessment-result.png" alt="Map Where You Are assessment result showing radar chart across four compass directions" loading="lazy" class="screenshot-thumb assessment-thumb"/>
            <span class="expand-hint">Tap to expand</span>
          </button>
        </div>

        <!-- Assessment Lightbox -->
        <div class="lightbox" id="assessment-lightbox" role="dialog" aria-modal="true" aria-label="Assessment result fullscreen view" aria-hidden="true">
          <button class="lightbox-close" id="assessment-lightbox-close" aria-label="Close fullscreen">✕</button>
          <img src="/assessment-result.png" alt="Map Where You Are assessment result" class="lightbox-img"/>
        </div>

        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs><linearGradient id="af1" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/></linearGradient></defs>
                <circle cx="24" cy="24" r="18" fill="none" stroke="url(#af1)" stroke-width="2.5"/>
                <line x1="24" y1="6" x2="24" y2="42" stroke="url(#af1)" stroke-width="1.5" opacity="0.3"/>
                <line x1="6" y1="24" x2="42" y2="24" stroke="url(#af1)" stroke-width="1.5" opacity="0.3"/>
                <polygon points="24,10 27,21 24,19 21,21" fill="url(#af1)"/>
                <circle cx="24" cy="24" r="3" fill="url(#af1)"/>
              </svg>
            </div>
            <h3>Four-Direction Mapping</h3>
            <p>See exactly where you stand across Self, Trust, Character, and Relationships, visualized as a radar chart unique to your answers.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs><linearGradient id="af2" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/></linearGradient></defs>
                <rect x="8" y="10" width="32" height="28" rx="4" fill="none" stroke="url(#af2)" stroke-width="2.5"/>
                <line x1="14" y1="19" x2="34" y2="19" stroke="url(#af2)" stroke-width="2" stroke-linecap="round"/>
                <line x1="14" y1="25" x2="30" y2="25" stroke="url(#af2)" stroke-width="2" stroke-linecap="round"/>
                <line x1="14" y1="31" x2="26" y2="31" stroke="url(#af2)" stroke-width="2" stroke-linecap="round"/>
                <circle cx="38" cy="12" r="7" fill="url(#af2)"/>
                <text x="38" y="16" text-anchor="middle" font-size="9" font-weight="700" fill="#fff">AI</text>
              </svg>
            </div>
            <h3>AI-Personalized Report</h3>
            <p>Your results generate a personalized written report, not a generic score. It reads your specific pattern and calls out what deserves your attention.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs><linearGradient id="af3" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/></linearGradient></defs>
                <circle cx="24" cy="17" r="9" fill="none" stroke="url(#af3)" stroke-width="2.5"/>
                <path d="M8 42 Q8 30 24 30 Q40 30 40 42" fill="none" stroke="url(#af3)" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="30" y1="13" x2="38" y2="8" stroke="url(#af3)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
                <circle cx="40" cy="7" r="4" fill="url(#af3)" opacity="0.4"/>
              </svg>
            </div>
            <h3>Email Only, No Name</h3>
            <p>Only your email is required. No name, no profile. Your data is secure and the answers stay private. Honesty without exposure.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs><linearGradient id="af4" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/></linearGradient></defs>
                <circle cx="24" cy="24" r="18" fill="none" stroke="url(#af4)" stroke-width="2.5"/>
                <line x1="24" y1="24" x2="24" y2="11" stroke="url(#af4)" stroke-width="3" stroke-linecap="round"/>
                <line x1="24" y1="24" x2="33" y2="29" stroke="url(#af4)" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="2.5" fill="url(#af4)"/>
              </svg>
            </div>
            <h3>About 10 Minutes</h3>
            <p>27 questions and a short open-text section. Long enough to get something real. Short enough to do it today.</p>
          </div>
        </div>

        <div class="cta-group">
          <a href="https://map.themoderncompass.io" class="button primary" target="_blank" rel="noopener">
            Take the Assessment →
          </a>
          <a href="/newsletter/" class="button ghost">
            Subscribe for Discount
          </a>
        </div>
      </div>
    </div>

    <!-- Featured App: Impulse Wallet -->
    <div class="featured-app">
      <div class="featured-badge">Featured App</div>
      <div class="featured-content">
        <div class="app-info">
          <div class="app-icon">
            <img src="/impulsewallet.png" alt="Impulse Wallet logo" class="app-logo-icon" />
          </div>
          <div class="app-meta">
            <h2>Impulse Wallet</h2>
            <p class="app-tagline">Gamified accountability for self-control and habit tracking</p>
          </div>
        </div>

        <p class="app-description">
          Impulse Wallet turns self-control into a game. Every good choice earns you $1. Every slip costs you $1. It's a virtual wallet, no real money, but the stakes feel surprisingly real. That's the point.
        </p>
        <p class="app-description">
          Built on the Modern Compass philosophy of <strong>progress over perfection</strong>, Impulse Wallet isn't about being flawless. It's about awareness. When you track choices, the good and the bad, patterns emerge. You start to see yourself more clearly. And clarity leads to change.
        </p>

        <!-- App Screenshot -->
        <div class="app-screenshot-wrap">
          <button class="screenshot-btn" id="screenshot-btn" aria-label="View full screenshot">
            <img src="/main-wallet-interface.png" alt="Impulse Wallet main interface" loading="lazy" class="screenshot-thumb"/>
            <span class="expand-hint">Tap to expand</span>
          </button>
        </div>

        <!-- Lightbox -->
        <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Screenshot fullscreen view" aria-hidden="true">
          <button class="lightbox-close" id="lightbox-close" aria-label="Close fullscreen">✕</button>
          <img src="/main-wallet-interface.png" alt="Impulse Wallet main interface" class="lightbox-img"/>
        </div>

        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi1" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Dollar sign -->
                <text x="24" y="32" text-anchor="middle" font-size="26" font-weight="700" fill="url(#fi1)" font-family="Georgia, serif">$</text>
                <!-- Up arrow (top-left) -->
                <line x1="9" y1="20" x2="9" y2="8" stroke="url(#fi1)" stroke-width="2.5" stroke-linecap="round"/>
                <polyline points="5,13 9,8 13,13" fill="none" stroke="url(#fi1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Down arrow (bottom-right) -->
                <line x1="39" y1="28" x2="39" y2="40" stroke="url(#fi1)" stroke-width="2.5" stroke-linecap="round"/>
                <polyline points="35,35 39,40 43,35" fill="none" stroke="url(#fi1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>$1 Up / $1 Down</h3>
            <p>Simple virtual wallet system. Good choices earn a dollar. Bad ones cost one. No complexity, just honest scorekeeping.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi2" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Clock face -->
                <circle cx="24" cy="28" r="16" fill="none" stroke="url(#fi2)" stroke-width="2.5"/>
                <!-- Hour hand (pointing up-left) -->
                <line x1="24" y1="28" x2="18" y2="20" stroke="url(#fi2)" stroke-width="2.5" stroke-linecap="round"/>
                <!-- Minute hand (pointing right) -->
                <line x1="24" y1="28" x2="33" y2="28" stroke="url(#fi2)" stroke-width="2" stroke-linecap="round"/>
                <!-- Undo arc at top -->
                <path d="M16 11 Q24 4 32 11" fill="none" stroke="url(#fi2)" stroke-width="2.5" stroke-linecap="round"/>
                <polyline points="13,14 16,11 20,14" fill="none" stroke="url(#fi2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>15-Minute Undo</h3>
            <p>Made an entry in haste? You have a 15-minute grace period to undo it. No permanent punishment for accidental taps.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi3" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Calendar box -->
                <rect x="6" y="13" width="28" height="26" rx="3" fill="none" stroke="url(#fi3)" stroke-width="2.5"/>
                <!-- Header bar -->
                <line x1="6" y1="21" x2="34" y2="21" stroke="url(#fi3)" stroke-width="2"/>
                <!-- Binding pins -->
                <line x1="14" y1="9" x2="14" y2="17" stroke="url(#fi3)" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="26" y1="9" x2="26" y2="17" stroke="url(#fi3)" stroke-width="2.5" stroke-linecap="round"/>
                <!-- Refresh arc -->
                <path d="M38 24 Q46 32 38 40" fill="none" stroke="url(#fi3)" stroke-width="2.5" stroke-linecap="round"/>
                <polyline points="35,22 38,24 41,21" fill="none" stroke="url(#fi3)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Weekly Resets</h3>
            <p>Every week is a fresh start. The slate clears so you can focus on this week's effort, not last week's failures.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi4" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Person head -->
                <circle cx="24" cy="14" r="8" fill="none" stroke="url(#fi4)" stroke-width="2.5"/>
                <!-- Person shoulders/body -->
                <path d="M8 44 Q8 30 24 30 Q40 30 40 44" fill="none" stroke="url(#fi4)" stroke-width="2.5" stroke-linecap="round"/>
                <!-- Lock body -->
                <rect x="18" y="27" width="12" height="9" rx="2" fill="url(#fi4)" opacity="0.85"/>
                <!-- Lock shackle -->
                <path d="M20 27 Q20 21 24 21 Q28 21 28 27" fill="none" stroke="url(#fi4)" stroke-width="2.5"/>
              </svg>
            </div>
            <h3>Anonymous Accounts</h3>
            <p>No email required. Your data stays private. Accountability without the vulnerability of sharing personal information.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi5" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Person 1 head -->
                <circle cx="17" cy="13" r="7" fill="none" stroke="url(#fi5)" stroke-width="2.5"/>
                <!-- Person 1 body -->
                <path d="M4 44 Q4 31 17 31 Q26 31 28 37" fill="none" stroke="url(#fi5)" stroke-width="2.5" stroke-linecap="round"/>
                <!-- Person 2 head (offset, behind) -->
                <circle cx="31" cy="13" r="7" fill="none" stroke="url(#fi5)" stroke-width="2.5" opacity="0.6"/>
                <!-- Person 2 body -->
                <path d="M20 44 Q22 31 31 31 Q44 31 44 44" fill="none" stroke="url(#fi5)" stroke-width="2.5" stroke-linecap="round" opacity="0.6"/>
              </svg>
            </div>
            <h3>Accountability Rooms</h3>
            <p>Compare weekly scores with friends, family, or a partner. Social accountability without judgment, just friendly competition.</p>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="fi6" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                  </linearGradient>
                </defs>
                <!-- Axis lines -->
                <line x1="7" y1="42" x2="7" y2="8" stroke="#e5e7eb" stroke-width="2" stroke-linecap="round"/>
                <line x1="7" y1="42" x2="43" y2="42" stroke="#e5e7eb" stroke-width="2" stroke-linecap="round"/>
                <!-- Trending up line (imperfect but heading up) -->
                <polyline points="7,40 14,34 20,36 27,25 34,23 43,13" fill="none" stroke="url(#fi6)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Data points -->
                <circle cx="14" cy="34" r="3" fill="url(#fi6)"/>
                <circle cx="20" cy="36" r="3" fill="url(#fi6)"/>
                <circle cx="27" cy="25" r="3" fill="url(#fi6)"/>
                <circle cx="34" cy="23" r="3" fill="url(#fi6)"/>
                <!-- Arrow tip -->
                <polyline points="39,10 43,13 40,17" fill="none" stroke="url(#fi6)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Progress Over Perfection</h3>
            <p>The goal isn't a perfect score. It's intentional effort. Impulse Wallet rewards showing up, not being flawless.</p>
          </div>
        </div>

        <div class="who-its-for">
          <h3>Who It's For</h3>
          <p>Impulse Wallet is built for people who want a judgment-free way to work on self-control. Whether you're trying to eat better, spend less, exercise more, or simply become more aware of your daily choices, this app gives your intentions a scoreboard.</p>
          <p>If you've ever said "I want to be better about [thing]" but never had a way to measure it, this is your tool.</p>
        </div>

        <div class="cta-group">
          <a href="/newsletter/" class="button primary">
            Subscribe to Get Access
          </a>
        </div>
      </div>
    </div>

    <!-- Coming Soon Apps -->
    <div class="coming-soon-section">
      <h2>Coming Soon</h2>
      <p class="coming-soon-intro">More tools are in the works, each one rooted in the Modern Compass framework and designed to make personal growth more tangible.</p>
      <div class="coming-soon-grid">
        <div class="coming-soon-card">
          <div class="cs-badge">Coming Soon</div>
          <div class="cs-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="cs2" x1="0" y1="0" x2="0" y2="48" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#b324a7"/><stop offset="1" stop-color="#0087c9"/>
                </linearGradient>
              </defs>
              <!-- Axis lines -->
              <line x1="6" y1="42" x2="44" y2="42" stroke="#e5e7eb" stroke-width="2" stroke-linecap="round"/>
              <line x1="6" y1="42" x2="6" y2="8" stroke="#e5e7eb" stroke-width="2" stroke-linecap="round"/>
              <!-- Bars (growing left to right) -->
              <rect x="10" y="32" width="8" height="10" rx="2" fill="url(#cs2)" opacity="0.45"/>
              <rect x="22" y="23" width="8" height="19" rx="2" fill="url(#cs2)" opacity="0.72"/>
              <rect x="34" y="13" width="8" height="29" rx="2" fill="url(#cs2)"/>
            </svg>
          </div>
          <h3>Compass Tracker</h3>
          <p>Track your growth across the four compass directions over time. See patterns in where you're investing energy, spot the areas you keep neglecting, and watch your direction evolve week by week.</p>
        </div>
      </div>
      <div class="coming-soon-cta">
        <p>Subscribe to the newsletter to be the first to know when these launch.</p>
        <a href="/newsletter/" class="button ghost">Stay in the Loop</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .apps-page {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .page-header {
    max-width: 680px;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-size: 1.1rem;
    color: var(--text-muted, #4b5563);
    line-height: 1.6;
  }

  /* Featured App Card */
  .featured-app {
    position: relative;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .featured-badge {
    display: inline-block;
    background: linear-gradient(135deg, #b324a7, #0087c9);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 1.5rem;
  }

  .new-badge {
    background: linear-gradient(135deg, #0087c9, #b324a7);
  }

  .assessment-card {
    border-color: rgba(179, 36, 167, 0.2);
    background: linear-gradient(180deg, rgba(179, 36, 167, 0.02) 0%, #fff 60%);
  }

  .assessment-thumb {
    width: 320px !important;
    border-radius: 12px !important;
  }

  .assessment-access {
    background: linear-gradient(135deg, rgba(179, 36, 167, 0.06), rgba(0, 135, 201, 0.06));
    border-color: rgba(179, 36, 167, 0.2);
  }

  .assessment-access p {
    color: #374151;
  }

  .assessment-access a {
    color: #b324a7;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .app-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .app-icon {
    flex-shrink: 0;
  }

  .app-logo-icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    object-fit: cover;
    display: block;
  }

  .app-meta h2 {
    font-size: 1.75rem;
    margin: 0 0 0.25rem;
    color: var(--primary-color, #1a1a1a);
  }

  .app-tagline {
    color: var(--text-muted, #4b5563);
    font-size: 1rem;
    margin: 0;
  }

  .app-description {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #374151;
    margin: 0;
  }

  /* App Screenshot */
  .app-screenshot-wrap {
    display: flex;
    justify-content: center;
  }

  .screenshot-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    display: inline-block;
